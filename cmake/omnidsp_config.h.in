// cmake/omnidsp_config.h.in
// This file is processed by CMake's configure_file command.
// Defines backend availability as compile-time constants (1 or 0).

#ifndef OMNIDSP_CONFIG_H
#define OMNIDSP_CONFIG_H

// --- Backend Availability Flags ---
// These are set to 1 if the backend was successfully configured and
// included in the build by CMake, otherwise 0.

// Default backend should always be available
#define OMNIDSP_HAS_BACKEND_DEFAULT @OMNIDSP_HAS_BACKEND_DEFAULT_VALUE@

// Optional Backends
#define OMNIDSP_HAS_BACKEND_ACCELERATE @OMNIDSP_HAS_BACKEND_ACCELERATE_VALUE@
#define OMNIDSP_HAS_BACKEND_ONEMKL @OMNIDSP_HAS_BACKEND_ONEMKL_VALUE@

// Add #define lines for any other optional backends you add
// #define OMNIDSP_HAS_BACKEND_CUDA @OMNIDSP_HAS_BACKEND_CUDA_VALUE@

#endif // OMNIDSP_CONFIG_H
