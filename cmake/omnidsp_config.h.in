// cmake/omnidsp_config.h.in (Refactored v3 - Explicit 1/0)
// This file is processed by CMake's configure_file command.
// Defines backend enablement status as compile-time constants (1 or 0).

#ifndef OMNIDSP_CONFIG_H
#define OMNIDSP_CONFIG_H

// --- Backend Enablement Flags ---
// Use #cmakedefine to ensure macros are defined as 1 if TRUE, or left undefined.
// The #ifndef blocks then define them as 0 if they were left undefined.

// Default backend (should always be TRUE/1)
#cmakedefine OMNIDSP_ENABLED_BACKEND_DEFAULT @OMNIDSP_ENABLED_BACKEND_DEFAULT@
#ifndef OMNIDSP_ENABLED_BACKEND_DEFAULT
#define OMNIDSP_ENABLED_BACKEND_DEFAULT 0
#endif

// Optional Backends
#cmakedefine OMNIDSP_ENABLED_BACKEND_ACCELERATE @OMNIDSP_ENABLED_BACKEND_ACCELERATE@
#ifndef OMNIDSP_ENABLED_BACKEND_ACCELERATE
#define OMNIDSP_ENABLED_BACKEND_ACCELERATE 0
#endif

#cmakedefine OMNIDSP_ENABLED_BACKEND_ONEMKL @OMNIDSP_ENABLED_BACKEND_ONEMKL@
#ifndef OMNIDSP_ENABLED_BACKEND_ONEMKL
#define OMNIDSP_ENABLED_BACKEND_ONEMKL 0
#endif

#cmakedefine OMNIDSP_ENABLED_BACKEND_INTELIPP @OMNIDSP_ENABLED_BACKEND_INTELIPP@
#ifndef OMNIDSP_ENABLED_BACKEND_INTELIPP
#define OMNIDSP_ENABLED_BACKEND_INTELIPP 0
#endif

// Add similar blocks for any other optional backends you add
// #cmakedefine OMNIDSP_ENABLED_BACKEND_CUDA @OMNIDSP_ENABLED_BACKEND_CUDA@
// #ifndef OMNIDSP_ENABLED_BACKEND_CUDA
// #define OMNIDSP_ENABLED_BACKEND_CUDA 0
// #endif


// --- Sanity Check (Optional but Recommended) ---
// Ensure all macros are defined as either 0 or 1 after the blocks above.
#if OMNIDSP_ENABLED_BACKEND_DEFAULT != 0 && OMNIDSP_ENABLED_BACKEND_DEFAULT != 1
#error "OMNIDSP_ENABLED_BACKEND_DEFAULT must be 0 or 1"
#endif
#if OMNIDSP_ENABLED_BACKEND_ACCELERATE != 0 && OMNIDSP_ENABLED_BACKEND_ACCELERATE != 1
#error "OMNIDSP_ENABLED_BACKEND_ACCELERATE must be 0 or 1"
#endif
#if OMNIDSP_ENABLED_BACKEND_ONEMKL != 0 && OMNIDSP_ENABLED_BACKEND_ONEMKL != 1
#error "OMNIDSP_ENABLED_BACKEND_ONEMKL must be 0 or 1"
#endif
#if OMNIDSP_ENABLED_BACKEND_INTELIPP != 0 && OMNIDSP_ENABLED_BACKEND_INTELIPP != 1
#error "OMNIDSP_ENABLED_BACKEND_INTELIPP must be 0 or 1"
#endif
// Add checks for other backends...


#endif // OMNIDSP_CONFIG_H
