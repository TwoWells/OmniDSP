# OmniDSP/cmake/Config.cmake.in
#
# This file is configured by CMake during the build of OmniDSP to produce
# OmniDSPConfig.cmake. Other CMake projects can then use:
#   find_package(OmniDSP REQUIRED)
# to find and use the OmniDSP library.

# --- Standard CMake Package Initialization ---
# @PACKAGE_INIT@ will be replaced by CMake with standard package setup code.
# It defines OmniDSP_FOUND, OmniDSP_VERSION, etc.
# It also sets up PACKAGE_PREFIX_DIR to the installation prefix.
@PACKAGE_INIT@

# --- Find Dependencies of OmniDSP ---
# List all PUBLIC and INTERFACE dependencies of your OmniDSP library here.
# These are libraries that a consuming project will also need to find and link against.
# The versions specified here use variables defined in OmniDSP's main build (e.g., in cmake/depend.cmake).

# Boost dependency
# If OmniDSP's public headers include Boost headers, or if it links publicly to Boost targets.
message(STATUS "OmniDSPConfig.cmake: Finding dependency: Boost ${OMNIDSP_REQUIRED_BOOST_VERSION}")
find_dependency(Boost ${OMNIDSP_REQUIRED_BOOST_VERSION} CONFIG REQUIRED)

# Google Highway dependency
# If OmniDSP's public headers include Highway headers, or if it links publicly to Highway targets.
message(STATUS "OmniDSPConfig.cmake: Finding dependency: hwy ${OMNIDSP_REQUIRED_HIGHWAY_VERSION}")
find_dependency(hwy ${OMNIDSP_REQUIRED_HIGHWAY_VERSION} CONFIG REQUIRED)

# spdlog dependency (add ONLY if spdlog is a PUBLIC dependency)
# message(STATUS "OmniDSPConfig.cmake: Finding dependency: spdlog")
# find_dependency(spdlog CONFIG REQUIRED)

# Add find_dependency() calls for any other PUBLIC/INTERFACE dependencies here.
# If a dependency is optional for your library's core functionality but was enabled
# in the build of OmniDSP that is being packaged, you might make its find_dependency
# conditional or not REQUIRED, though this adds complexity.

# --- Load OmniDSP Targets ---
# The OmniDSPTargets.cmake file (generated by install(EXPORT ...)) defines the
# imported targets for the OmniDSP library (e.g., OmniDSP::OmniDSP).
# CMAKE_CURRENT_LIST_DIR is the directory where this OmniDSPConfig.cmake file is located.
if(NOT TARGET @PROJECT_NAME@::@PROJECT_NAME@) # Checks for OmniDSP::OmniDSP
    include("${CMAKE_CURRENT_LIST_DIR}/@PROJECT_NAME@Targets.cmake")
endif()

# --- Set Useful Variables (Optional but good practice) ---
# These can make it easier for consuming projects, though modern CMake
# encourages direct use of imported targets (e.g., OmniDSP::OmniDSP).

# Main library target
set(@PROJECT_NAME@_LIBRARIES @PROJECT_NAME@::@PROJECT_NAME@)

# Include directories for the installed headers.
# @CMAKE_INSTALL_INCLUDEDIR@ is one of the PATH_VARS passed to configure_package_config_file,
# so it will be an absolute path to the installed include directory.
# Assuming headers are installed to <prefix>/include/OmniDSP
set(@PROJECT_NAME@_INCLUDE_DIRS "${PACKAGE_PREFIX_DIR}/@CMAKE_INSTALL_INCLUDEDIR@/@PROJECT_NAME@")

# --- Check for Requested Components (if your library has components) ---
# If OmniDSP were to have components like "Core", "Analysis", etc., that a user
# could request via find_package(OmniDSP COMPONENTS Core Analysis), you would
# use check_required_components here. For now, assuming no components.
# check_required_components(@PROJECT_NAME@)

message(STATUS "OmniDSPConfig.cmake: OmniDSP library and its dependencies found successfully.")
