# === Build Output ===
# --- Ignore the build directory regardless of its name case ---
[Bb]uild/

# --- Ignore common VS build output directories (often redundant if using a separate build/ folder) ---
[Dd]ebug/
[Rr]elease/
x64/
Win32/
[Dd]ebug*/
[Rr]elease*/

# === CMake Generated Files ===
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
compile_commands.json

# === Python ===
# --- Virtual environment folder ---
.venv/
venv/
# --- Python cache and bytecode ---
__pycache__/
*.pyc
*.pyo
*.pyd
# --- Distribution / Installation artifacts ---
dist/
*.egg-info/
wheels/

# === IDE / Editor Specific ===
# --- VS Code ---
.vscode/
# !.vscode/settings.json
# !.vscode/launch.json
# !.vscode/extensions.json
# --- CLion ---
.idea/
