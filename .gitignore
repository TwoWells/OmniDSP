# -*- mode: gitignore; -*-

# === Build Output ===
# Ignore the build directory regardless of its name case
[Bb]uild/
# Ignore scikit-build-core temporary build directory
_skbuild/
# Ignore common VS build output directories (often redundant if using a separate build/ folder)
[Dd]ebug/
[Rr]elease/
x64/
Win32/
[Dd]ebug*/
[Rr]elease*/
# Output directories (if different from 'build')
bin/

# === CMake Generated Files ===
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
compile_commands.json
CTestTestfile.cmake

# === Python ===
# Virtual environment folders
.venv/
venv/
venv_build/
env/
ENV/
env.bak/
venv.bak/

# Python cache and bytecode
__pycache__/
*.py[co]
*$py.class

# Distribution / Installation artifacts
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
wheelhouse/
*.whl

# PyInstaller files
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Python Test Artifacts / Coverage Reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/

# Environment variables file
.env*

# Local settings override
local.py

# Maybe redundant if venv/ is ignored, but harmless
# /Lib/
# /Include/
# /Scripts/

# Spyder project settings
.spyderproject
.spyderworkspace

# Rope project settings
.ropeproject

# === Jupyter Notebook ===
# Checkpoints directory
.ipynb_checkpoints/

# === Conda ===
# Ignore environment specification lock files if you use them
# environment.lock.yml
# Usually part of the conda env itself, but ignore if it appears locally
# conda-meta/

# === IDE / Editor Specific ===
# VS Code
.vscode/
# Uncomment below to keep specific VSCode files
# !.vscode/settings.json
# !.vscode/launch.json
# !.vscode/extensions.json
*.code-workspace

# CLion
.idea/

# Vim temporary/swap files
*~
*.sw[op]
Session.vim
.netrwhist

# Emacs temporary files
.#*

# === Visual Studio Specific ===
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.VC.db
*.[Ss]u[o]
*.sdf
*.opensdf
*.ilk
*.map
*.exp
*.pdb # Program Debug Database

# === OS Specific ===
# macOS system files
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder/
Temporary Items/
.apdisk

# Windows system files
Thumbs.db
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/

# === C / C++ Build Artifacts ===
# Often redundant if inside build/, but kept for robustness
# Compiled Object files
*.slo
*.lo
*.o
*.obj
# Precompiled Headers
*.gch
*.pch
# Compiled Dynamic libraries
*.so
*.dylib
*.dll
# Compiled Static libraries
*.lai
*.la
*.a
*.lib
# Executables
*.exe
*.out
*.app

# === Other Temporary Files ===
*.log
*.tmp
*.temp

# === General Extras ===
# Backup files
*.[bB][aA][kK]
*.bak
*.orig
