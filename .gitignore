# -*- mode: gitignore; -*-
# General-purpose gitignore for C++/Python/CMake projects

# === Build Output ===
# --- Ignore the build directory regardless of its name case ---
[Bb]uild/
# --- Ignore scikit-build-core temporary build directory ---
_skbuild/
# --- Ignore common VS build output directories (often redundant if using a separate build/ folder) ---
[Dd]ebug/
[Rr]elease/
x64/
Win32/
[Dd]ebug*/
[Rr]elease*/

# === CMake Generated Files ===
CMakeCache.txt
CMakeFiles/
CMakeScripts/
cmake_install.cmake
install_manifest.txt
compile_commands.json

# === Python ===
# --- Virtual environment folders ---
.venv/
venv/
venv_build/

# --- Python cache and bytecode ---
__pycache__/
*.py[co]

# --- Distribution / Installation artifacts ---
dist/
wheelhouse/
*.egg-info/
wheels/
*.whl

# --- Python Test Artifacts ---
.pytest_cache/
.coverage*
htmlcov/

# === IDE / Editor Specific ===
# --- VS Code ---
.vscode/
# !.vscode/settings.json # Keep settings if desired
# !.vscode/launch.json # Keep launch configs if desired
# !.vscode/extensions.json # Keep recommended extensions if desired
# --- CLion ---
.idea/
# --- Other Editor Temp/Swap Files ---
*~
*.sw[op] # Covers .swp and .swo

# === Visual Studio Specific ===
*.sln
*.vcxproj
*.vcxproj.filters
*.vcxproj.user
*.VC.db
*.[Ss]u[o]
*.sdf
*.opensdf

# === OS Specific ===
# --- macOS ---
.DS_Store
# --- Windows ---
Thumbs.db

# === Other Temporary Files ===
*.log
*.tmp
*.temp

# === Python Extras ===
.env* # Ignore .env and .env.* files
local.py
# Maybe redundant if venv/ is ignored, but harmless
/Lib/
/Include/
/Scripts/

# === C++ Extras ===
# Often redundant if inside build/, but kept for robustness
*.obj
*.lib # Keep this, but note .lib is also import lib on Windows
*.pdb
*.ilk
*.map
*.exp # Export file often generated with DLLs
*.dll # Generally ignore DLLs unless they are vendored dependencies
*.exe # Ignore executables generated by C++ builds

# === General Extras ===
# Backup files
*.[bB][aA][kK]
*.bak
*.orig
