// cmake/omnidsp_config.h.in (Refactored v3 - Explicit 1/0)
// This file is processed by CMake's configure_file command.
// Defines backend enablement status as compile-time constants (1 or 0).

#ifndef OMNIDSP_CONFIG_HPP
#define OMNIDSP_CONFIG_HPP

// --- Backend Enablement Flags ---
// Use #cmakedefine to ensure macros are defined as 1 if TRUE, or left undefined.
// The #ifndef blocks then define them as 0 if they were left undefined.

// Default backend (should always be TRUE/1)
#cmakedefine OMNIDSP_BACKEND_DEFAULT_ENABLED @OMNIDSP_BACKEND_DEFAULT_ENABLED@
#ifndef OMNIDSP_BACKEND_DEFAULT_ENABLED
#define OMNIDSP_BACKEND_DEFAULT_ENABLED 0
#endif

// Optional Backends
#cmakedefine OMNIDSP_BACKEND_ACCELERATE_ENABLED @OMNIDSP_BACKEND_ACCELERATE_ENABLED@
#ifndef OMNIDSP_BACKEND_ACCELERATE_ENABLED
#define OMNIDSP_BACKEND_ACCELERATE_ENABLED 0
#endif

#cmakedefine OMNIDSP_BACKEND_ONEMKL_ENABLED @OMNIDSP_BACKEND_ONEMKL_ENABLED@
#ifndef OMNIDSP_BACKEND_ONEMKL_ENABLED
#define OMNIDSP_BACKEND_ONEMKL_ENABLED 0
#endif

#cmakedefine OMNIDSP_BACKEND_INTELIPP_ENABLED @OMNIDSP_BACKEND_INTELIPP_ENABLED@
#ifndef OMNIDSP_BACKEND_INTELIPP_ENABLED
#define OMNIDSP_BACKEND_INTELIPP_ENABLED 0
#endif

// Add similar blocks for any other optional backends you add
// #cmakedefine OMNIDSP_BACKEND_CUDA_ENABLED @OMNIDSP_BACKEND_CUDA_ENABLED@
// #ifndef OMNIDSP_BACKEND_CUDA_ENABLED
// #define OMNIDSP_BACKEND_CUDA_ENABLED 0
// #endif


// --- Sanity Check (Optional but Recommended) ---
// Ensure all macros are defined as either 0 or 1 after the blocks above.
#if OMNIDSP_BACKEND_DEFAULT_ENABLED != 0 && OMNIDSP_BACKEND_DEFAULT_ENABLED != 1
#error "OMNIDSP_BACKEND_DEFAULT_ENABLED must be 0 or 1"
#endif
#if OMNIDSP_BACKEND_ACCELERATE_ENABLED != 0 && OMNIDSP_BACKEND_ACCELERATE_ENABLED != 1
#error "OMNIDSP_BACKEND_ACCELERATE_ENABLED must be 0 or 1"
#endif
#if OMNIDSP_BACKEND_ONEMKL_ENABLED != 0 && OMNIDSP_BACKEND_ONEMKL_ENABLED != 1
#error "OMNIDSP_BACKEND_ONEMKL_ENABLED must be 0 or 1"
#endif
#if OMNIDSP_BACKEND_INTELIPP_ENABLED != 0 && OMNIDSP_BACKEND_INTELIPP_ENABLED != 1
#error "OMNIDSP_BACKEND_INTELIPP_ENABLED must be 0 or 1"
#endif
// Add checks for other backends...


#endif // OMNIDSP_CONFIG_HPP
