# Example Config.cmake.in
@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Find dependencies required by OmniDSP's public interface or implementation
find_dependency(Boost REQUIRED)
find_dependency(highway CONFIG REQUIRED)
# Add find_dependency(MKL) here IF consumers of OmniDSP need direct access
# to MKL types/functions through OmniDSP's headers, which is unlikely with PIMPL.

# Include the targets file generated by install(EXPORT ...)
include("${CMAKE_CURRENT_LIST_DIR}/OmniDSPTargets.cmake")

