# Config.cmake.in - Template for OmniDSP CMake package configuration

@PACKAGE_INIT@

# === Find Dependencies ===
# Use find_dependency() to find libraries that OmniDSP PUBLICLY depends on.
# This ensures users of OmniDSP also find and link these dependencies correctly.
# CMake variables OMNIDSP_USES_MKL/OMNIDSP_USES_ACCELERATE must be set correctly
# in the main CMakeLists.txt before configure_package_config_file is called.

if(@OMNIDSP_USES_MKL@)
    # If OmniDSP was built using MKL, require users to find MKL too.
    find_dependency(MKL REQUIRED)
endif()

if(@OMNIDSP_USES_ACCELERATE@)
    # If OmniDSP was built using Accelerate, require users to find Accelerate too.
    find_dependency(Accelerate REQUIRED)
endif()

# Add find_dependency() for any other PUBLIC dependencies of omnidsp here

# === Include Targets ===
# Include the file generated by install(EXPORT OmniDSPTargets ...)
# This defines the OmniDSP::omnidsp imported target.
include("${CMAKE_CURRENT_LIST_DIR}/OmniDSPTargets.cmake")

# === Check Components ===
# (Optional) If you install different components, add checks here.
# check_required_components(OmniDSP)

message(STATUS "Found OmniDSP version ${PACKAGE_VERSION} (using ${CMAKE_CURRENT_LIST_DIR}/OmniDSPConfig.cmake)")